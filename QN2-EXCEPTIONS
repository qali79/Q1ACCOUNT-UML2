package vu.mysterytest.java;

public class RiskyTest {

    static int risky(int x) {
        try {
            if (x == 0)
                throw new ArithmeticException();

            return 10 / x;

        } catch (ArithmeticException e) {
            System.out.println("caught");
            return -1;

        } finally {
            System.out.println("done");
        }
    }

    public static void main(String[] args) {

        System.out.println("Call risky(0):");
        System.out.println("Returned: " + risky(0));

        System.out.println();

        System.out.println("Call risky(2):");
        System.out.println("Returned: " + risky(2));
    }
}